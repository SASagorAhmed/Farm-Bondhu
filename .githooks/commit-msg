#!/bin/sh
# Remove tool-injected attribution lines from the final commit message.
# Cursor may invoke: git commit --trailer 'Made-with: Cursor' ...
# or Co-authored-by: Cursor <cursoragent@cursor.com>
# This hook strips those lines so policy in gitcommit.md is enforced.

commit_msg_file="$1"
if [ -z "$commit_msg_file" ] || [ ! -f "$commit_msg_file" ]; then
  exit 0
fi

tmp="${commit_msg_file}.strip.$$"
# Portable grep -E: Made-with, Generated by AI, Co-authored-by mentioning Cursor or cursoragent@
if ! grep -v -E '^(Made-with: Cursor|Generated by AI)$|^Co-authored-by:.*([Cc]ursor|cursoragent@)' "$commit_msg_file" >"$tmp" 2>/dev/null; then
  rm -f "$tmp"
  exit 0
fi

mv -f "$tmp" "$commit_msg_file"
