# =============================================================================
# Copy to .env and fill in. Never commit .env.
# =============================================================================

# --- PostgreSQL (e.g. Supabase session pooler or any Postgres host) ---
# Use your real project ref, host, user, password. URL-encode special characters in the password.
DATABASE_URL=postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@[YOUR_DB_HOST]:5432/postgres
# Serverless-safe DB pool settings (recommended on Vercel to avoid max client exhaustion).
# Keep low unless you run long-lived servers.
DB_POOL_MAX=1
DB_IDLE_TIMEOUT_SEC=20
DB_CONNECT_TIMEOUT_SEC=10

# On startup, create missing public tables/columns (idempotent). Set to false if migrations own the schema.
AUTO_CREATE_SCHEMA=true

# Fixed HTTP port (default 3001). npm run dev runs scripts/free-port.js first to clear it.
BACKEND_PORT=3001

NODE_ENV=development

# Include every browser origin that calls this API.
# Local + Vercel example:
# CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

# Local default:
API_PUBLIC_URL=http://localhost:3001
# Vercel example:
# API_PUBLIC_URL=https://your-backend.vercel.app

# Web app origin for order emails (View order links). Defaults to first CORS_ORIGIN or http://localhost:5173
FRONTEND_URL=http://localhost:5173
# FRONTEND_URL=https://your-frontend.vercel.app

# --- Auth (Postgres + JWT; no Supabase Auth required) ---
# Signs access + refresh tokens (min 16 characters). Generate locally:
#   npm run gen-auth-secret
AUTH_JWT_SECRET=
# Optional: bootstrap official super admin (see npm run seed:official-admin). In production always set a strong password.
# OFFICIAL_SUPER_ADMIN_EMAIL=farmbondhu.officials@gmail.com
# OFFICIAL_SUPER_ADMIN_PASSWORD=

# Optional legacy alias if you already have a value:
# JWT_SECRET=
# Optional: only if migrating old tokens
# SUPABASE_JWT_SECRET=

# Required for signup OTP: encrypts the pending password between send-otp and verify-otp (min 16 characters).
# Generate both auth secrets: cd backend && npm run gen-auth-secret — copy both lines into .env.
REGISTRATION_SECRET=

# --- Optional: Supabase REST / Realtime metadata ---
# Frontend realtime subscriptions use VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY.
# Backend does not require Supabase realtime credentials for current implementation.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- ZegoCloud (UIKit prebuilt + POST /v1/tools/zego-token) ---
# Used today: HMAC kit token generation for the browser SDK.
ZEGOCLOUD_APP_ID=
ZEGOCLOUD_SERVER_SECRET=
# Optional / not read by this codebase yet: Zego console “App sign”, callback secret, or
# server URL are for webhooks or other server products—add wiring if you implement those flows.

# --- AI ---
OPENROUTER_API_KEY=
# Default farm-chat model when client omits model
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# Comma-separated allowlist for farm chat model picker
OPENROUTER_CHAT_MODELS=deepseek/deepseek-v4-flash,moonshotai/kimi-k2.6:free
# Optional JSON map of model id -> display label, e.g. {"deepseek/deepseek-v4-flash:free":"DeepSeek (free)"}
# OPENROUTER_CHAT_MODEL_LABELS=
# Cow photo head assist only (must support vision); not used for text chat
OPENROUTER_VISION_MODEL=google/gemma-4-31b-it:free
# Direct Google Gemini. Keep this backend-only; never expose the key in frontend env.
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-flash-latest
GEMINI_VISION_MODEL=gemini-2.5-flash
# Tried in order only when the primary Gemini vision model is rate-limited or temporarily unavailable.
GEMINI_VISION_FALLBACK_MODELS=gemini-2.0-flash-lite,gemini-flash-lite-latest
ENABLE_GEMINI_CHAT_MODEL=true
# Provider behavior: openrouter | gemini | off
AI_CHAT_PROVIDER=openrouter
AI_CHAT_FALLBACK_PROVIDER=off
AI_VISION_PROVIDER=gemini
AI_VISION_FALLBACK_PROVIDER=off
# Set to false to disable POST /v1/cow-estimations/assist-direction only
COW_DIRECTION_ASSIST_ENABLED=true

# --- Email (Brevo) — OTP registration, password reset, marketplace order updates ---
# Option A (simplest): Brevo Transactional API + verified sender (no SMTP vars needed).
BREVO_API_KEY=
# Option B: SMTP relay (Brevo SMTP & API → copy login + SMTP key).
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Required for either option: verified sender, e.g. "FarmBondhu <noreply@yourdomain.com>"
MAIL_FROM=
