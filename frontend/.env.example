# Copy to .env. Express API origin (no trailing slash). Login/sign-up call ${VITE_API_URL}/api/v1/auth/* then /api/v1/me.
VITE_API_URL=http://127.0.0.1:3001
# Vercel frontend environment example:
# VITE_API_URL=https://your-backend.vercel.app

# Supabase Realtime (for cross-user live UI updates without refresh).
# Use anon key only in frontend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
